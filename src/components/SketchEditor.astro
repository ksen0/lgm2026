---
import SketchConsole from './SketchConsole.astro';
const { background = false } = Astro.props;
---

<div class={`sketch-wrap ${background ? 'bg-mode' : ''}`}>
<div id="p5-host"></div>

  <div class="editor-panel">
    <div id="codemirror-host"></div>
    <button id="run-btn">run</button>
  </div>

    <SketchConsole />

</div>
<div id="sketch-stats">FPS: -- | F: --</div>


<script>
import { EditorState } from '@codemirror/state';
import { EditorView } from '@codemirror/view';
import { basicSetup } from 'codemirror';
import { javascript } from '@codemirror/lang-javascript';
import { oneDark } from '@codemirror/theme-one-dark';
import p5Source from '/node_modules/p5/lib/p5.min.js?raw';

const DEFAULT_CODE = `function setup() {
  createCanvas(400, 400);
  describe('circle follows mouse');
}
function draw() {
  background(20);
  circle(mouseX, mouseY, 100);
}`;

function runSketch(code: string, w = 400, h = 400) {
  (window as any).__consoleClear?.();
  const host = document.getElementById('p5-host')!;
  host.innerHTML = '';
  const iframe = document.createElement('iframe');
  iframe.style.cssText = `border:none;width:${w}px;height:${h}px;`;

const bridge = `<script>
  const _p = window.parent;
  const _log   = console.log.bind(console);
  const _warn  = console.warn.bind(console);
  const _error = console.error.bind(console);
  const _info  = console.info.bind(console);
  const _debug = console.debug.bind(console);
  const _table = console.table.bind(console);

  console.log   = (...a) => { _log(...a);   _p.__consoleLog?.(...a); };
  console.warn  = (...a) => { _warn(...a);  _p.__consoleWarn?.(...a); };
  console.error = (...a) => { _error(...a); _p.__consoleError?.(...a); };
  console.info  = (...a) => { _info(...a);  _p.__consoleLog?.(...a); };
  console.debug = (...a) => { _debug(...a); _p.__consoleLog?.(...a); };
  console.table = (...a) => { _table(...a); _p.__consoleLog?.(JSON.stringify(a[0], null, 2)); };

  window.onerror = (msg, src, line, col, err) => {
    const text = (err ? err.toString() : msg) + (line ? ' (line ' + line + ')' : '');
    _error(text);
    _p.__consoleError?.(text);
    return false;
  };
  window.addEventListener('unhandledrejection', (e) => {
    const text = e.reason?.toString?.() ?? String(e.reason);
    _error(text);
    _p.__consoleError?.(text);
  });

  // catch p5 errors which use a custom error handler
  window.addEventListener('error', (e) => {
    if (e.error && e.error !== window._lastReportedError) {
      window._lastReportedError = e.error;
      const text = e.error.toString() + (e.lineno ? ' (line ' + e.lineno + ')' : '');
      _p.__consoleError?.(text);
    }
  });

  setInterval(() => {
  try {
    _p.__sketchStats?.({ fps: Math.round(frameRate()), frame: frameCount });
  } catch(e) {}
 
  const c = document.querySelector('canvas');
  if (c) _p.postMessage({ type: 'sketchSize', w: c.offsetWidth, h: c.offsetHeight }, '*');

}, 100);

<\/script>`;

  iframe.srcdoc = `<!DOCTYPE html><html><body style="margin:0">
    ${bridge}
    <script>${p5Source}<\/script>
    <script>${code}<\/script>
    </body></html>`;
  host.appendChild(iframe);
}

const state = EditorState.create({
  doc: DEFAULT_CODE,
  extensions: [
    basicSetup,
    javascript(),
    oneDark,
    EditorView.lineWrapping,  // ← add here
  ],
});

const view = new EditorView({
  state,
  parent: document.getElementById('codemirror-host')!,
});

const isBg = document.querySelector('.bg-mode') !== null;
const W = isBg ? 100 : 400;
const H = isBg ? 100 : 400;

runSketch(DEFAULT_CODE, W, H);

(window as any).loadSnippet = (code: string) => {
  view.dispatch({
    changes: { from: 0, to: view.state.doc.length, insert: code }
  });
  runSketch(code, W, H);
  panel?.classList.remove('active');
  runBtn.textContent = 'edit';
};

const stats = document.getElementById('sketch-stats')!;
(window as any).__sketchStats = ({ fps, frame }: { fps: number, frame: number }) => {
  stats.textContent = `FPS: ${fps} | F: ${frame}`;
};

const panel = document.querySelector('.editor-panel');
const runBtn = document.getElementById('run-btn')!;

if (isBg) runBtn.textContent = 'edit';

runBtn.addEventListener('click', () => {
  if (isBg && !panel?.classList.contains('active')) {
    // first click = activate editor
    panel?.classList.add('active');
    runBtn.textContent = 'run';
    view.focus();
  } else {
    // already active = run sketch
    runSketch(view.state.doc.toString(), W, H);
    if (isBg) {
      panel?.classList.remove('active');
      runBtn.textContent = 'edit';
      runBtn.blur();
    }
  }
});

view.dom.addEventListener('blur', () => {
  setTimeout(() => {
    if (!panel?.contains(document.activeElement)) {
      panel?.classList.remove('active');
      if (isBg) runBtn.textContent = 'edit';
    }
  }, 100);
});

window.addEventListener('message', (e) => {
  if (e.data?.type === 'sketchSize' && isBg) {
    const iframe = document.querySelector('#p5-host iframe') as HTMLIFrameElement;
    if (!iframe) return;
    iframe.style.width  = e.data.w + 'px';
    iframe.style.height = e.data.h + 'px';
  }
});
</script>

<style>
  .sketch-wrap {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
#sketch-stats {
  position: fixed;
  top: 0.75rem;
  right: 1rem;
  z-index: 20;
  font-family: monospace;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.5);
  pointer-events: none;
}
  /* Background mode: canvas fills viewport, editor floats */
  .bg-mode {
    display: block;
  }
.bg-mode #p5-host {
  position: fixed;
  bottom: 0;
  right: 0;
  width: auto;
  height: auto;
}
.bg-mode #p5-host iframe {
  display: block;
  border: none;
}
.bg-mode .editor-panel {
  position: fixed;
  top: 2rem;
  left: 2rem;
  z-index: 10;
  opacity: 0.35;
  transition: opacity 0.2s ease;
  background: rgba(10, 10, 10, 0.85);   /* darker base */
  backdrop-filter: blur(8px);
  border-radius: 8px;
  padding: 0.75rem;
width: min(80ch, 90vw);          /* ← max ~80 chars wide */
  height: 50vh;                    /* ← always half viewport */
  
  box-shadow: 0 0 0 1px rgba(255,255,255,0.08);
}

.bg-mode #codemirror-host {
  flex: 1;
  overflow-y: auto;
  min-height: 0;        /* required for flex children to shrink */
}

.bg-mode #codemirror-host .cm-editor {
  height: 100%;
}

.bg-mode #codemirror-host .cm-scroller {
  overflow-y: auto;
}

.bg-mode .editor-panel {
  pointer-events: none;   /* pass mouse through when idle */
}
.bg-mode .editor-panel.active {
  pointer-events: auto;
  opacity: 1;
}
/* small always-clickable tab */
.bg-mode .editor-tab {
  position: fixed;
  top: 2rem;
  left: 2rem;
  z-index: 11;
  pointer-events: auto;
  background: rgba(10,10,10,0.75);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 4px;
  padding: 0.2rem 0.6rem;
  color: #eee;
  font-size: 0.75rem;
  cursor: pointer;
  backdrop-filter: blur(6px);
}


/* force CM text to never go transparent */
.bg-mode .editor-panel .cm-editor {
  color: inherit;
}

  /* Landing mode */
  .editor-panel {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  #run-btn {
    align-self: flex-end;
    padding: 0.3rem 0.8rem;
    cursor: pointer;
    border: 1px solid #555;
    background: #222;
    color: #fff;
    border-radius: 4px;

  }
  #run-btn:hover { background: #444; }
.bg-mode #run-btn {
  pointer-events: auto;
  align-self: flex-end;
}


</style>