---
import SketchConsole from './SketchConsole.astro';
const { background = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class={`sketch-wrap ${background ? 'bg-mode' : ''}`}>
  <div class="editor-panel">
    <div id="codemirror-host"></div>
    <div class="btn-row">
      <slot name="actions" />
      <button id="hide-btn">hide</button>
      <button id="run-btn">run</button>
    </div>
  </div>

  <div id="p5-host" data-base={base}></div>

  <SketchConsole />
</div>
<div id="sketch-stats">FPS: -- | F: --</div>

<script>
import { EditorState } from '@codemirror/state';
import { EditorView } from '@codemirror/view';
import { basicSetup } from 'codemirror';
import { javascript } from '@codemirror/lang-javascript';
import { oneDark } from '@codemirror/theme-one-dark';
import p5Source from '/node_modules/p5/lib/p5.min.js?raw';
import p5WebgpuSource from '/node_modules/p5/lib/p5.webgpu.js?raw';

const DEFAULT_CODE = `function setup() {
  createCanvas(windowWidth, windowHeight);
}
function draw() {
  circle(mouseX, mouseY, 100);
}`;

const isBg = document.querySelector('.bg-mode') !== null;
const W = isBg ? window.innerWidth : 400;
const H = isBg ? window.innerHeight : 400;

let activeLoadId = 0;
let pendingLoadId = 0;

const host = document.getElementById('p5-host')!;
const base = host.dataset.base ?? '';

function p5Scripts(code: string): string {
  const hasCompute = code.includes('compute(');
  const hasFont = code.includes('loadFont(');

  const fontScript = hasFont
    ? `<script src="${base}/p5.woff2.js"><\/script>`
    : '';

  if (hasCompute) {
    return `<script src="${base}/rc-p5.js"><\/script><script src="${base}/rc-p5.webgpu.js"><\/script>${fontScript}`;
  }
  return `<script>${p5Source}<\/script><script>${p5WebgpuSource}<\/script>${fontScript}`;
}

function p5ImportsInfo(code: string): string {

  let importsInfo = "";

  if (code.includes('compute(')) {
    importsInfo += " * https://raw.esm.sh/pr/p5@1ec7e78/lib/p5.min.js (experimental/pre-release)";
    importsInfo += "\n * https://raw.esm.sh/pr/p5@1ec7e78/lib/p5.webgpu.js (experimental/pre-release)";
  } else {
    importsInfo += " * https://cdn.jsdelivr.net/npm/p5@2/lib/p5.min.js";
    if (code.includes('WEBGPU')) {
    importsInfo += "\n * https://cdn.jsdelivr.net/npm/p5@2/lib/p5.webgpu.js";
    }
  }

  if (code.includes('loadFont(')) {
    importsInfo += " * https://github.com/davepagurek/p5.woff2";
  }
  return `${importsInfo}`;
}

function runSketch(code: string, w = 400, h = 400) {

  const requiresBlock = `\n\n/* Requires:\n${p5ImportsInfo(code)}\n */`;
  const existingBlock = /\n\n\/\* Requires:[\s\S]*?\n \*\//;
  const annotated = existingBlock.test(code)
    ? code.replace(existingBlock, requiresBlock)
    : code + requiresBlock;


  view.dispatch({ changes: { from: 0, to: view.state.doc.length, insert: annotated } });
  (window as any).__consoleClear?.();

  const loadId = ++pendingLoadId;
  activeLoadId = loadId;

  const iframe = document.createElement('iframe');
  iframe.dataset.loadId = String(loadId);
  iframe.style.cssText = `border: none; width: ${w}px; height: ${h}px; display: block;`;

  // In bg-mode the iframe is full-viewport so windowWidth/windowHeight work
  // correctly inside p5. The body is a flex container that right-centers the
  // canvas — a 400×400 sketch sits middle-right, a windowWidth×windowHeight
  // sketch fills the screen. flex-shrink:0 prevents flex from squishing the
  // canvas when it is smaller than the container.
  const bodyStyle = isBg
    ? 'margin:0;width:100vw;height:100vh;display:flex;align-items:center;justify-content:flex-end'
    : 'margin:0';
  const headExtra = isBg ? '<style>canvas{flex-shrink:0}</style>' : '';

  const bridge = `<script>
  const _p = window.parent;
  const _loadId = ${loadId};
  const _log   = console.log.bind(console);
  const _warn  = console.warn.bind(console);
  const _error = console.error.bind(console);
  const _info  = console.info.bind(console);
  const _debug = console.debug.bind(console);
  const _table = console.table.bind(console);

  console.log   = (...a) => { _log(...a);   _p.__consoleLog?.(...a); };
  console.warn  = (...a) => { _warn(...a);  _p.__consoleWarn?.(...a); };
  console.error = (...a) => { _error(...a); _p.__consoleError?.(...a); };
  console.info  = (...a) => { _info(...a);  _p.__consoleLog?.(...a); };
  console.debug = (...a) => { _debug(...a); _p.__consoleLog?.(...a); };
  console.table = (...a) => { _table(...a); _p.__consoleLog?.(JSON.stringify(a[0], null, 2)); };

  window.onerror = (msg, src, line, col, err) => {
    const text = (err ? err.toString() : msg) + (line ? ' (line ' + line + ')' : '');
    _error(text); _p.__consoleError?.(text); return false;
  };
  window.addEventListener('unhandledrejection', (e) => {
    const text = e.reason?.toString?.() ?? String(e.reason);
    _error(text); _p.__consoleError?.(text);
  });
  window.addEventListener('error', (e) => {
    if (e.error && e.error !== window._lastReportedError) {
      window._lastReportedError = e.error;
      const text = e.error.toString() + (e.lineno ? ' (line ' + e.lineno + ')' : '');
      _p.__consoleError?.(text);
    }
  });

  setInterval(() => {
    const c = document.querySelector('canvas');
    if (!c) return;
    try {
      _p.postMessage({ type: 'sketchStats', loadId: _loadId, fps: Math.round(frameRate()), frame: frameCount }, '*');
    } catch(e) {}
  }, 100);
<\/script>`;

  iframe.srcdoc = `<!DOCTYPE html><html><head>${headExtra}<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet"></head><body style="${bodyStyle}">
    ${bridge}
    ${p5Scripts(code)}
    <script>${code}<\/script></body></html>`;

  host.querySelectorAll('iframe').forEach(f => f.remove());
  host.appendChild(iframe);
}

const state = EditorState.create({
  doc: DEFAULT_CODE,
  extensions: [basicSetup, javascript(), oneDark, EditorView.lineWrapping],
});

const view = new EditorView({
  state,
  parent: document.getElementById('codemirror-host')!,
});

runSketch(DEFAULT_CODE, W, H);

const panel   = document.querySelector('.editor-panel');
const runBtn  = document.getElementById('run-btn')!;
const hideBtn = document.getElementById('hide-btn')!;

function setActive(active: boolean) {
  if (active) {
    panel?.classList.add('active');
    runBtn.textContent = 'run';
    hideBtn.style.visibility = 'visible';
  } else {
    panel?.classList.remove('active');
    runBtn.textContent = 'edit';
    hideBtn.style.visibility = 'hidden';
  }
}

if (isBg) setActive(false);

runBtn.addEventListener('click', () => {
  if (isBg && !panel?.classList.contains('active')) {
    setActive(true);
    view.focus();
  } else {
    runSketch(view.state.doc.toString(), W, H);
  }
});

hideBtn.addEventListener('click', () => {
  setActive(false);
  hideBtn.blur();
});

(window as any).loadSnippet = (code: string) => {
  view.dispatch({ changes: { from: 0, to: view.state.doc.length, insert: code } });
  runSketch(code, W, H);
  setActive(false);
};

const stats = document.getElementById('sketch-stats')!;

window.addEventListener('message', (e) => {
  if (e.data?.type === 'sketchStats') {
    if (e.data.loadId !== activeLoadId) return;
    stats.textContent = `FPS: ${e.data.fps} | F: ${e.data.frame}`;
  }
});
</script>

<style>
  .sketch-wrap {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .editor-panel {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding:30px;
  }

  .btn-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: flex-end;
    padding: 0.3rem 0.5rem;
  }

  #run-btn {
    padding: 0.3rem 0.8rem;
    cursor: pointer;
    border: 1px solid #555;
    background: #222;
    color: #fff;
    border-radius: 4px;
  }
  #run-btn:hover { background: #444; }

  #sketch-stats {
  background:rgb(0,0,0);
  padding:5px;
    position: fixed;
    top: 0.75rem;
    right: 1rem;
    z-index: 20;
    font-family: monospace;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
    pointer-events: none;
  }

  /* ── bg mode ── */
  .bg-mode { display: block; }

  /* full-viewport iframe host; pointer-events:none so page content is still
     interactive — the iframe itself handles its own mouse events */
  .bg-mode #p5-host {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
  }

  .bg-mode #p5-host iframe {
    width: 100%;
    height: 100%;
    pointer-events: auto;
  }

  .bg-mode .editor-panel {
box-sizing: border-box;
    position: fixed;
    bottom: 0;
    left: 0;
    z-index: 10;

    width: 50%;
    max-width: 800px;
    height: 60vh;
    display: flex;
    flex-direction: column;
    background: rgba(0,0,0,0.9);
    backdrop-filter: blur(8px);
    opacity: 0.4;
    pointer-events: none;
  }

  .bg-mode .editor-panel.active {
    opacity: 1;
    pointer-events: auto;
  }

  .bg-mode .btn-row {
    pointer-events: auto;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 0.3rem 0.5rem;
  }

  .bg-mode #codemirror-host {
    flex: 1;
    overflow-y: auto;
    min-height: 0;
  }

  .bg-mode #codemirror-host .cm-editor { height: 100%; }
  .bg-mode #codemirror-host .cm-scroller { overflow-y: auto; }

  .bg-mode #run-btn,
  .bg-mode #hide-btn {
    pointer-events: auto;
    border: none;
    background: transparent;
    color: #aaa;
    font-family: monospace;
    font-size: 0.8rem;
    padding: 0.2rem 0.4rem;
    border-radius: 0;
    cursor: pointer;
  }
  .bg-mode #run-btn:hover,
  .bg-mode #hide-btn:hover { color: #fff; background: transparent; }
</style>