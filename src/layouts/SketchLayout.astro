---
import SketchEditor from '../components/SketchEditor.astro';
import p5Source from '/node_modules/p5/lib/p5.min.js?raw';

const { frontmatter } = Astro.props;
const { slides = [] } = frontmatter;

const snippetModules = import.meta.glob('../snippets/*.js', { eager: true, query: '?raw', import: 'default' });

const resolved = slides.map(({ snippet, description, url }: { snippet: string, description: string, url?: string }) => ({
  name: snippet,
  description: description ?? '',
  url: url ?? '',
  code: snippetModules[`../snippets/${snippet}.js`] as string ?? '',
}));

const first = resolved[0] ?? { name: '', code: '', description: '', url: '' };

const qrCode = `
  let qrImg;

  async function loadQr(url) {
    clear();
    qrImg = null;
    if (!url) return;
    let apiUrl = "https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=" + encodeURIComponent(url);
    qrImg = await loadImage(apiUrl);
    redraw();
  }

  function setup() {
    createCanvas(200, 200);
    noLoop();
    window.addEventListener('message', (e) => {
      if (e.data?.type === 'qrUrl') loadQr(e.data.url);
    });
  }

  function draw() {
    clear();
    if (qrImg) image(qrImg, 10, 10, 180, 180);
  }`;

const qrSrcdoc = `<!DOCTYPE html><html><body style="margin:0">
<script>${p5Source}<\/script>
<script>${qrCode}<\/script>
</body></html>`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>p5.js @ lgm 2026</title>


    
    <style is:global>

    @font-face {
  font-family: 'https://ksen0.github.io/lgm2026/Space Grotesk';
  src: url('Space_Grotesk/SpaceGrotesk-VariableFont_wght.ttf') format('truetype');
  font-weight: 300 700;
}

      html, body { margin: 0; padding: 0; overflow: hidden; background: #000; }

      #qr-frame {
        position: fixed;
        top: 0;
        left: 0;
        width: 200px;
        height: 200px;
        z-index: -20;
        border: none;
        pointer-events: none;
        display: none;
      }
      #qr-frame.visible { display: block; }

      #slide-desc {
        position: fixed;
        top:0px;
        height: 40vh;
        padding-left:30px;
        padding-right:30px;
        left: 0;
        width: 50%;
        max-width: 800px;
        box-sizing: border-box;
        overflow: hidden;
        z-index: 15;
        font-family: Space Grotesk;
        font-size: 1.2em;
        font-weight: 300;
        color: #fff;
        /*-webkit-text-stroke: 3px black;
        paint-order: stroke fill;*/
        background:rgb(0, 0, 0, 0.8);
        white-space: normal;
        word-break: break-word;
        display: flex;
        align-items: flex-start;
        flex-direction: column;
        justify-content: flex-end;
      }

      .snippet-btns {
        display: flex;
        flex: 1;
        gap: 0;
      }
      .snippet-btns button {
        padding: 0.2rem 0.6rem;
        background: transparent;
        color: #666;
        border: none;
        border-right: 1px solid rgba(255,255,255,0.08);
        cursor: pointer;
        font-size: 0.8rem;
        font-family: monospace;
        transition: color 0.15s;
        pointer-events: auto;
      }
      .snippet-btns button:hover { color: #eee; }
      .snippet-btns button.active { color: #fff; }


      a {
        color: rgb(241, 103, 142) !important;
      }
    </style>
  </head>
  <body>
    <iframe id="qr-frame" srcdoc={qrSrcdoc}></iframe>

    <div id="slide-desc"></div>

    <SketchEditor background={true}>
      <div slot="actions" class="snippet-btns">
        {resolved.map(({ name, code, description, url }) => (
          <button data-code={code} data-description={description} data-url={url}>{name}</button>
        ))}
      </div>
    </SketchEditor>

    <script define:vars={{ firstCode: first.code, firstDescription: first.description, firstName: first.name, firstUrl: first.url }}>
      const desc = document.getElementById('slide-desc');
      const qf = document.getElementById('qr-frame');

      function showDescription(text) {
        desc.innerHTML = text;
        desc.offsetHeight;
      }

      function loadQr(url) {
        qf.contentWindow.postMessage({ type: 'qrUrl', url }, '*');
        if (url) qf.classList.add('visible');
        else qf.classList.remove('visible');
      }

      qf.addEventListener('load', () => {
        if (firstUrl) loadQr(firstUrl);
      });

      document.querySelectorAll('.snippet-btns button').forEach(btn => {
        btn.addEventListener('click', () => {
          const code = btn.dataset.code;
          const description = btn.dataset.description ?? '';
          const url = btn.dataset.url ?? '';
          document.querySelectorAll('.snippet-btns button').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          window.loadSnippet?.(code);
          if (description) showDescription(description);
          loadQr(url);
        });
      });

      window.addEventListener('load', () => {
        if (firstCode) {
          window.loadSnippet?.(firstCode);
          document.querySelectorAll('.snippet-btns button')[0]?.classList.add('active');
        }
        if (firstDescription) showDescription(firstDescription);
      });
    </script>
  </body>
</html>