---
import SketchEditor from '../components/SketchEditor.astro';

const { frontmatter } = Astro.props;
const slides = frontmatter.slides ?? [];

const snippetModules = import.meta.glob('../snippets/*.js', { eager: true, query: '?raw', import: 'default' });

const resolved = slides.map(({ snippet, description }: { snippet: string, description: string }) => ({
  name: snippet,
  description,
  code: snippetModules[`../snippets/${snippet}.js`] as string ?? '',
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>sketch</title>
    <style>
      :root { --panel-w: min(640px, 90vw); }

      html, body { margin: 0; padding: 0; overflow: hidden; background: #111; }

      #slide-desc {
        position: fixed;
        bottom: 50vh;
        left: 0;
        width: var(--panel-w);
        max-width: var(--panel-w);
        box-sizing: border-box;
        overflow: hidden;
        z-index: 15;
        pointer-events: none;
        font-family: sans-serif;
        font-size: clamp(1rem, 2.5vw, 2rem);
        font-weight: 700;
        color: #fff;
        -webkit-text-stroke: 3px black;
        paint-order: stroke fill;
        padding: 0.4rem 0.5rem;
        white-space: normal;
        word-break: break-word;
      }

      .snippet-btns {
        display: flex;
        flex: 1;
        gap: 0;
      }
      .snippet-btns button {
        padding: 0.2rem 0.6rem;
        background: transparent;
        color: #666;
        border: none;
        border-right: 1px solid rgba(255,255,255,0.08);
        cursor: pointer;
        font-size: 0.8rem;
        font-family: monospace;
        transition: color 0.15s;
        pointer-events: auto;
      }
      .snippet-btns button:hover { color: #eee; }
      .snippet-btns button.active { color: #fff; }
    </style>
  </head>
  <body>
    <div id="slide-desc"></div>

    <SketchEditor background={true}>
      <div slot="actions" class="snippet-btns">
        {resolved.map(({ name, code, description }) => (
          <button data-code={code} data-description={description}>{name}</button>
        ))}
      </div>
    </SketchEditor>

    <script>
      const desc = document.getElementById('slide-desc')!;

      function showDescription(text: string) {
        desc.textContent = text;
      }

      document.querySelectorAll('.snippet-btns button').forEach(btn => {
        btn.addEventListener('click', () => {
          const code = (btn as HTMLElement).dataset.code!;
          const description = (btn as HTMLElement).dataset.description ?? '';
          document.querySelectorAll('.snippet-btns button').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          (window as any).loadSnippet?.(code);
          if (description) showDescription(description);
        });
      });
    </script>
  </body>
</html>